                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="8" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" text="9" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <Button  fx:id="buttonSlash" styleClass="perimeterButton" mnemonicParsing="false" onAction="#operazione" prefHeight="45.0" prefWidth="0.0" text="/" GridPane.columnIndex="3" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="4" GridPane.rowIndex="2" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="5" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" text="6" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                  <Button  fx:id="buttonSub" styleClass="perimeterButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="1" GridPane.rowIndex="3" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="2" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="3" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                  <Button  fx:id="buttonAdd" styleClass="perimeterButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="+" GridPane.columnIndex="3" GridPane.rowIndex="3" />
                  <Button  fx:id="number" styleClass="numberAndVariableButton" contentDisplay="CENTER" mnemonicParsing="false" onAction="#inserimentoNumero" text="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <Button  styleClass="buttonEnter" mnemonicParsing="false" onAction="#enter" prefHeight="45.0" prefWidth="109.0" text="ENTER" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                  <Button  fx:id="number" styleClass="perimeterButton" mnemonicParsing="false" onAction="#inserimentoNumero" prefHeight="45.0" prefWidth="0.0" text="." GridPane.rowIndex="4" />
                  <Button  fx:id="buttonC" styleClass="perimeterButton" mnemonicParsing="false" onAction="#cancellaSingoloInserimento" text="C" GridPane.columnIndex="1" />
                  <Button  fx:id="buttonAC" styleClass="perimeterButton" mnemonicParsing="false" onAction="#cancellaNumero" text="AC" />
                  <Button  styleClass="perimeterButton" mnemonicParsing="false" onAction="#switchToOtherOperationDisplay" text="OO" GridPane.columnIndex="2" />
               </children>
            </GridPane>
         </children>
      </VBox>
      <HBox fx:id="HBox" alignment="CENTER" prefHeight="55.0" prefWidth="360.0" spacing="30.0" >
         <children>
            <Button fx:id="buttonCalculator" styleClass="topButton" contentDisplay="CENTER" mnemonicParsing="false" onAction="#switchToCalculatorDisplay" text="Calculator" />
            <Button fx:id="buttonVariabili" styleClass="topButton" contentDisplay="CENTER" mnemonicParsing="false" onAction="#switchToVariables1Display" text="Variable" />
            <Button fx:id="buttonStack" styleClass="topButton" contentDisplay="CENTER" mnemonicParsing="false" onAction="#switchToStack" text="Stack" />
         </children>
      </HBox>
   </children>
</AnchorPane>
