<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="anchorPane" minHeight="0.0" minWidth="0.0" prefHeight="373.0" prefWidth="350.0" stylesheets="@CalculatorStyle.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mgrav.ComplexNumberCalculator.CalculatorController">
   <children>
            <HBox fx:id="HBox" alignment="CENTER" prefHeight="55.0" prefWidth="360.0" spacing="30.0">
               <children>
                  <Button fx:id="buttonCalculator" mnemonicParsing="false" onAction="#switchToCalculatorDisplay" styleClass="topButton" text="Calculator" />
                  <Button fx:id="buttonVariabili" mnemonicParsing="false" onAction="#switchToVariables1Display" styleClass="topButton" text="Variable" />
                  <Button fx:id="buttonStack" mnemonicParsing="false" onAction="#switchToStack" styleClass="topButton" text="Stack" />
               </children>
            </HBox>
            <HBox prefHeight="305.0" prefWidth="350.0" layoutY="69.0">
               <children>
                  <ScrollPane hbarPolicy="NEVER" prefHeight="324.0" prefWidth="205.0" style="-fx-background-color: black;">
                    <content>
                      <AnchorPane fx:id="anchorPane" minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0" styleClass="anchorPane">
                           <children>
                              <TableView fx:id="stackTable" prefHeight="324.0" prefWidth="195.0" styleClass="stackTable">
                                 <columns>
                                    <TableColumn fx:id="stackClm" styleClass="stackTable" editable="false" prefWidth="250.0" sortType="DESCENDING" sortable="false" text="STACK" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
                           </children>
                        </AnchorPane>
                    </content>
                  </ScrollPane>
                  <VBox alignment="CENTER" nodeOrientation="LEFT_TO_RIGHT" prefHeight="324.0" prefWidth="161.0" spacing="20.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#controlStack" styleClass="stackButton" text="CLEAR" />
                        <Button mnemonicParsing="false" onAction="#controlStack" styleClass="stackButton" text="DROP" />
                        <Button mnemonicParsing="false" onAction="#controlStack" styleClass="stackButton" text="DUP" />
                        <Button mnemonicParsing="false" onAction="#controlStack" styleClass="stackButton" text="SWAP" />
                        <Button mnemonicParsing="false" onAction="#controlStack" styleClass="stackButton" text="OVER" />
                     </children>
                  </VBox>
               </children>
            </HBox>
   </children>
</AnchorPane>
